# 环境变量配置文件
# 复制此文件为 .env 并填入你的真实值
# cp .env.example .env

# 数据库（SQLite 文件路径，无需修改）
DATABASE_URL="file:./dev.db"

# NextAuth.js 配置
# NEXTAUTH_SECRET: JWT 签名密钥，必须修改！
#   生成方法: openssl rand -base64 32
# NEXTAUTH_URL: 站点域名，本地开发用 http://localhost:3005，生产环境改为你的域名
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"
NEXTAUTH_URL=https://your-domain.com

# 阿里云 OSS（可选，不配置则使用本地示例图片）
# OSS_REGION: 存储区域，如 oss-cn-guangzhou
# OSS_ACCESS_KEY_ID: AccessKey ID，从阿里云控制台获取
# OSS_ACCESS_KEY_SECRET: AccessKey Secret，从阿里云控制台获取
# OSS_BUCKET: 存储桶名称
OSS_REGION=oss-cn-guangzhou
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=

# 阿里云 VOD 视频点播（可选，不配置则视频走 OSS 存储）
# VOD_REGION: 服务区域，如 cn-shenzhen
# VOD_ACCESS_KEY_ID: AccessKey ID
# VOD_ACCESS_KEY_SECRET: AccessKey Secret
# VOD_SPACE_NAME: 视频空间名称
VOD_REGION=cn-shenzhen
VOD_ACCESS_KEY_ID=
VOD_ACCESS_KEY_SECRET=
VOD_SPACE_NAME=
